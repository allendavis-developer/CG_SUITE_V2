{
  "manifest_version": 3,
  "name": "CG Suite Research",
  "version": "1.2.4",
  "description": "Capture listing data from eBay, Cash Converters, and Cash Generator for CG Suite research forms.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "tabGroups",
    "windows"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://nospos.com/*",
    "https://*.nospos.com/*",
    "https://www.ebay.co.uk/*",
    "https://ebay.co.uk/*",
    "https://www.cashconverters.co.uk/*",
    "https://cashconverters.co.uk/*",
    "https://www.cashgenerator.co.uk/*",
    "https://cashgenerator.co.uk/*",
    "https://webepos.cashgenerator.co.uk/*",
    "https://uk.webuy.com/*",
    "https://www.webuy.com/*",
    "https://www.\u006d\u0061\u0073\u0074\u0065\u0072\u006d\u0065\u006c\u0074\u0067\u0072\u006f\u0075\u0070.com/*",
    "https://\u006d\u0061\u0073\u0074\u0065\u0072\u006d\u0065\u006c\u0074\u0067\u0072\u006f\u0075\u0070.com/*",
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*",
    "https://fonts.googleapis.com/*",
    "https://fonts.gstatic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost/*", "https://localhost/*", "http://127.0.0.1/*", "https://127.0.0.1/*"],
      "js": ["content-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.ebay.co.uk/*", "https://ebay.co.uk/*"],
      "js": ["shared/dom-utils.js", "shared/constants.js", "content-listings.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.cashconverters.co.uk/*", "https://cashconverters.co.uk/*"],
      "js": ["shared/dom-utils.js", "shared/constants.js", "content-listings.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.cashgenerator.co.uk/*", "https://cashgenerator.co.uk/*"],
      "js": ["shared/dom-utils.js", "shared/constants.js", "content-listings.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://uk.webuy.com/*", "https://www.webuy.com/*"],
      "js": [
        "shared/dom-utils.js",
        "shared/constants.js",
        "content-listings.js",
        "cex-scrape/cex-nav-parser.js",
        "cex-scrape/content-cex-nav-scrape.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://nospos.com/*", "https://*.nospos.com/*"],
      "js": ["shared/dom-utils.js", "shared/constants.js", "shared/nospos-park-overlay.js", "content-nospos.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://nospos.com/newagreement/*", "https://*.nospos.com/newagreement/*"],
      "js": ["shared/dom-utils.js", "shared/constants.js", "shared/nospos-park-overlay.js", "content-nospos-agreement-fill.js"],
      "run_at": "document_idle"
    }
  ]
}
